#!/usr/bin/env bash
set -euo pipefail

# claude-local — Claude Code wrapper for local Ollama models
#
# Wraps the Claude CLI so it talks to an Ollama instance instead of the
# Anthropic API.  Supports interactive setup, model discovery, and API-key
# authentication (for reverse-proxy setups like nginx).
#
# Usage:
#   claude-local                     — interactive model picker
#   claude-local <model> [args...]   — launch with a specific model
#   claude-local --setup             — (re)configure connection
#   claude-local --test              — test connectivity
#   claude-local --models            — list available models
#   claude-local --help              — show this help
#
# Environment / .env:
#   OLLAMA_HOST            Ollama server URL    (default: http://localhost:11434)
#   LITELLM_HOST           LiteLLM proxy URL    (default: http://localhost:4000)
#   OLLAMA_API_KEY         API key for auth-proxy setups
#   OLLAMA_DEFAULT_MODEL   Skip the picker and use this model

###############################################################################
# ANSI helpers
###############################################################################
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

###############################################################################
# Resolve config directory & .env
###############################################################################
# Resolve symlinks so SCRIPT_DIR points to the real repo, not the symlink parent
_real_source="${BASH_SOURCE[0]}"
while [[ -L "$_real_source" ]]; do
  _real_source="$(readlink "$_real_source")"
  [[ "$_real_source" != /* ]] && _real_source="$(dirname "${BASH_SOURCE[0]}")/$_real_source"
done
SCRIPT_DIR="$(cd "$(dirname "$_real_source")/.." && pwd)"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claude-local"

# Load .env — check project dir first, then config dir
if [[ -f "$SCRIPT_DIR/.env" ]]; then
  set -a; source "$SCRIPT_DIR/.env"; set +a
elif [[ -f "$CONFIG_DIR/.env" ]]; then
  set -a; source "$CONFIG_DIR/.env"; set +a
fi

# Defaults
OLLAMA_HOST="${OLLAMA_HOST:-http://localhost:11434}"
LITELLM_HOST="${LITELLM_HOST:-http://localhost:4000}"
OLLAMA_API_KEY="${OLLAMA_API_KEY:-}"
OLLAMA_DEFAULT_MODEL="${OLLAMA_DEFAULT_MODEL:-}"
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC="${CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC:-1}"

###############################################################################
# Helpers
###############################################################################
die()  { echo -e "${RED}error:${NC} $*" >&2; exit 1; }
info() { echo -e "${CYAN}::${NC} $*"; }
ok()   { echo -e "${GREEN}✓${NC} $*"; }
warn() { echo -e "${YELLOW}!${NC} $*"; }

need_cmd() {
  command -v "$1" &>/dev/null || die "'$1' is required but not found in PATH"
}

# Build curl auth header if API key is set
_auth_header() {
  if [[ -n "$OLLAMA_API_KEY" ]]; then
    echo "Authorization: Bearer $OLLAMA_API_KEY"
  fi
}

# Curl wrapper that adds auth + timeout
_curl() {
  local -a headers=()
  local auth
  auth="$(_auth_header)"
  [[ -n "$auth" ]] && headers+=(-H "$auth")
  curl -sf --connect-timeout 5 --max-time 10 "${headers[@]}" "$@"
}

###############################################################################
# API calls
###############################################################################
ollama_health() {
  # Ollama's root endpoint returns "Ollama is running"
  _curl "${OLLAMA_HOST}/" >/dev/null 2>&1
}

litellm_health() {
  # LiteLLM exposes /health
  # /health can block if models aren't loaded; /v1/models is fast and reliable
  _curl "${LITELLM_HOST}/v1/models" >/dev/null 2>&1
}

ollama_models() {
  # Try LiteLLM's /v1/models first (OpenAI format), fall back to Ollama /api/tags
  local litellm_models
  litellm_models=$(_curl "${LITELLM_HOST}/v1/models" 2>/dev/null || true)
  if [[ -n "$litellm_models" ]] && echo "$litellm_models" | jq -e '.data' &>/dev/null; then
    # Convert OpenAI /v1/models format to Ollama /api/tags format for consistency
    echo "$litellm_models" | jq '{models: [.data[] | {name: .id, model: .id, size: 0, modified_at: (.created // 0 | tostring)}]}'
    return
  fi
  # Fall back to Ollama native API
  _curl "${OLLAMA_HOST}/api/tags" 2>/dev/null
}

ollama_version() {
  _curl "${OLLAMA_HOST}/api/version" 2>/dev/null
}

###############################################################################
# Interactive setup
###############################################################################
run_setup() {
  echo -e "${BOLD}claude-local setup${NC}"
  echo -e "${DIM}Configure your Ollama connection${NC}"
  echo ""

  # Host
  local default_host="${OLLAMA_HOST}"
  read -rp "$(echo -e "${WHITE}Ollama host${NC} [${DIM}${default_host}${NC}]: ")" input_host
  local host="${input_host:-$default_host}"

  # LiteLLM host
  local default_litellm="${LITELLM_HOST}"
  read -rp "$(echo -e "${WHITE}LiteLLM proxy host${NC} [${DIM}${default_litellm}${NC}]: ")" input_litellm
  local litellm="${input_litellm:-$default_litellm}"

  # API key
  local default_key="${OLLAMA_API_KEY}"
  local key_display=""
  if [[ -n "$default_key" ]]; then
    key_display="${default_key:0:8}...${default_key: -4}"
  fi
  read -rp "$(echo -e "${WHITE}API key${NC} (blank if none) [${DIM}${key_display}${NC}]: ")" input_key
  local key="${input_key:-$default_key}"

  # Test connections
  echo ""
  OLLAMA_HOST="$host" OLLAMA_API_KEY="$key" LITELLM_HOST="$litellm"

  info "Testing Ollama at ${host}..."
  if ollama_health; then
    ok "Connected to Ollama"
    local ver
    ver=$(ollama_version 2>/dev/null | jq -r '.version // empty' 2>/dev/null || true)
    [[ -n "$ver" ]] && echo -e "  ${DIM}version: ${ver}${NC}"
  else
    warn "Could not reach Ollama at ${host}"
  fi

  info "Testing LiteLLM at ${litellm}..."
  if litellm_health; then
    ok "Connected to LiteLLM proxy"
  else
    warn "Could not reach LiteLLM at ${litellm} — you may need to deploy it first"
    echo -e "  ${DIM}Run: ./deploy/setup.sh${NC}"
  fi

  # Default model
  echo ""
  local default_model="${OLLAMA_DEFAULT_MODEL}"
  read -rp "$(echo -e "${WHITE}Default model${NC} (blank for interactive picker) [${DIM}${default_model}${NC}]: ")" input_model
  local model="${input_model:-$default_model}"

  # Write config
  mkdir -p "$CONFIG_DIR"
  cat > "$CONFIG_DIR/.env" <<ENVEOF
# claude-local configuration — generated $(date +%Y-%m-%d)
OLLAMA_HOST=${host}
LITELLM_HOST=${litellm}
OLLAMA_API_KEY=${key}
OLLAMA_DEFAULT_MODEL=${model}
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
ENVEOF
  chmod 600 "$CONFIG_DIR/.env"

  echo ""
  ok "Config saved to ${CONFIG_DIR}/.env"
  echo -e "${DIM}Run 'claude-local' to start, or 'claude-local --test' to verify.${NC}"
}

###############################################################################
# Connection test
###############################################################################
run_test() {
  echo -e "${BOLD}claude-local${NC} — connectivity test"
  echo -e "${DIM}Ollama:  ${OLLAMA_HOST}${NC}"
  echo -e "${DIM}LiteLLM: ${LITELLM_HOST}${NC}"
  [[ -n "$OLLAMA_API_KEY" ]] && echo -e "${DIM}Auth:    API key (${OLLAMA_API_KEY:0:8}...)${NC}"
  echo ""

  local -a auth_h=()
  local ah
  ah="$(_auth_header)"
  [[ -n "$ah" ]] && auth_h=(-H "$ah")

  # --- Ollama direct ---
  echo -e "${WHITE}Ollama (${OLLAMA_HOST})${NC}"
  if ollama_health; then
    ok "Reachable"
  else
    warn "Cannot reach Ollama at ${OLLAMA_HOST}"
  fi

  local ver
  ver=$(ollama_version 2>/dev/null | jq -r '.version // empty' 2>/dev/null || true)
  [[ -n "$ver" ]] && ok "Version: ${ver}"

  local model_json
  model_json=$(_curl "${OLLAMA_HOST}/api/tags" 2>/dev/null || true)
  if [[ -n "$model_json" ]]; then
    local count
    count=$(echo "$model_json" | jq '.models | length' 2>/dev/null || echo 0)
    ok "${count} model(s) available"
    if [[ "$count" -gt 0 ]]; then
      echo "$model_json" | jq -r '.models[].name' 2>/dev/null | while read -r m; do
        echo -e "  ${MAGENTA}•${NC} $m"
      done
    fi
  fi

  # --- LiteLLM proxy ---
  echo ""
  echo -e "${WHITE}LiteLLM (${LITELLM_HOST})${NC}"
  if litellm_health; then
    ok "Reachable"
  else
    warn "Cannot reach LiteLLM at ${LITELLM_HOST}"
    echo -e "  ${DIM}Deploy with: ./deploy/setup.sh${NC}"
  fi

  # Check /v1/models via LiteLLM
  local litellm_models
  litellm_models=$(_curl "${LITELLM_HOST}/v1/models" 2>/dev/null || true)
  if [[ -n "$litellm_models" ]] && echo "$litellm_models" | jq -e '.data' &>/dev/null; then
    local lcount
    lcount=$(echo "$litellm_models" | jq '.data | length' 2>/dev/null || echo 0)
    ok "${lcount} model(s) via /v1/models"
  fi

  # Check Anthropic Messages API via LiteLLM
  info "Checking /v1/messages (Anthropic format)..."
  local msgs_url="${LITELLM_HOST}/v1/messages"
  local status_code
  status_code=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 5 \
    -X POST "${auth_h[@]}" \
    -H "Content-Type: application/json" \
    -d '{"model":"test","max_tokens":1,"messages":[{"role":"user","content":"hi"}]}' \
    "$msgs_url" 2>/dev/null) || true

  if [[ -z "$status_code" || "$status_code" == "000" ]]; then
    warn "/v1/messages not reachable"
  elif [[ "$status_code" =~ ^(200|400|401|422)$ ]]; then
    ok "/v1/messages responds (HTTP ${status_code}) — Claude Code compatible"
  else
    warn "/v1/messages returned HTTP ${status_code}"
  fi

  # Check OpenAI-compat via LiteLLM
  info "Checking /v1/chat/completions (OpenAI format)..."
  local oai_url="${LITELLM_HOST}/v1/chat/completions"
  status_code=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 5 \
    -X POST "${auth_h[@]}" \
    -H "Content-Type: application/json" \
    -d '{"model":"test","max_tokens":1,"messages":[{"role":"user","content":"hi"}]}' \
    "$oai_url" 2>/dev/null) || true

  if [[ -z "$status_code" || "$status_code" == "000" ]]; then
    warn "/v1/chat/completions not reachable"
  elif [[ "$status_code" =~ ^(200|400|401|422)$ ]]; then
    ok "/v1/chat/completions responds (HTTP ${status_code})"
  else
    warn "/v1/chat/completions returned HTTP ${status_code}"
  fi

  echo ""
  ok "Test complete"
}

###############################################################################
# List models
###############################################################################
run_list_models() {
  if ! ollama_health; then
    die "Cannot reach Ollama at ${OLLAMA_HOST}"
  fi

  local model_json
  model_json=$(ollama_models) || die "Failed to fetch models"

  local count
  count=$(echo "$model_json" | jq '.models | length')

  echo -e "${BOLD}Models on ${CYAN}${OLLAMA_HOST}${NC}  ${DIM}(${count})${NC}"
  echo ""

  if [[ "$count" -eq 0 ]]; then
    warn "No models found. Pull one with: ollama pull <model>"
    exit 0
  fi

  # Table: name | size | modified
  printf "  ${WHITE}%-40s %-10s %s${NC}\n" "NAME" "SIZE" "MODIFIED"
  echo "$model_json" | jq -r '.models[] | [.name, (.size / 1073741824 | . * 100 | floor / 100 | tostring + " GB"), .modified_at[:10]] | @tsv' 2>/dev/null | \
    while IFS=$'\t' read -r name size modified; do
      printf "  ${MAGENTA}%-40s${NC} %-10s ${DIM}%s${NC}\n" "$name" "$size" "$modified"
    done
}

###############################################################################
# Interactive model picker
###############################################################################
pick_model() {
  if ! ollama_health; then
    die "Cannot reach Ollama at ${OLLAMA_HOST}. Run 'claude-local --setup' to configure."
  fi

  local model_json
  model_json=$(ollama_models) || die "Failed to fetch models"

  local count
  count=$(echo "$model_json" | jq '.models | length')

  if [[ "$count" -eq 0 ]]; then
    die "No models available on ${OLLAMA_HOST}. Pull one with: ollama pull <model>"
  fi

  # Build array
  local -a models=()
  while IFS= read -r line; do
    models+=("$line")
  done < <(echo "$model_json" | jq -r '.models[].name')

  # Single model — auto-select
  if [[ "$count" -eq 1 ]]; then
    echo -e "${CYAN}Auto-selecting${NC} ${BOLD}${models[0]}${NC} ${DIM}(only model available)${NC}"
    SELECTED_MODEL="${models[0]}"
    return
  fi

  # Multiple models — show picker
  echo -e "${BOLD}Select a model:${NC}"
  echo ""
  for i in "${!models[@]}"; do
    printf "  ${WHITE}%2d)${NC} %s\n" "$((i + 1))" "${models[$i]}"
  done
  echo ""

  while true; do
    read -rp "$(echo -e "${CYAN}Enter number${NC} [1-${count}]: ")" choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= count )); then
      SELECTED_MODEL="${models[$((choice - 1))]}"
      return
    fi
    # Also accept model name directly
    for m in "${models[@]}"; do
      if [[ "$m" == "$choice" ]]; then
        SELECTED_MODEL="$m"
        return
      fi
    done
    echo -e "${RED}Invalid selection${NC}"
  done
}

###############################################################################
# Launch Claude Code
###############################################################################
launch_claude() {
  local model="$1"
  shift

  need_cmd claude

  echo -e "${GREEN}Launching${NC} ${BOLD}Claude Code${NC} → ${CYAN}${LITELLM_HOST}${NC} / ${MAGENTA}${BOLD}${model}${NC}"
  echo ""

  # Point Claude Code at the LiteLLM proxy (Anthropic Messages API compatible)
  export ANTHROPIC_BASE_URL="${LITELLM_HOST}"
  export ANTHROPIC_API_KEY="${OLLAMA_API_KEY:-not-needed}"
  export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC="${CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC}"

  # Launch — exec replaces this process
  # --bare: use only ANTHROPIC_API_KEY (skip OAuth/keychain), skip hooks/plugins
  # --add-dir: re-enable CLAUDE.md discovery for the target project directory
  # --effort low: disable extended thinking (local models don't support it)
  exec claude --bare --add-dir "$(pwd)" --effort low --model "$model" "$@"
}

###############################################################################
# Help
###############################################################################
show_help() {
  cat <<'HELPEOF'
claude-local — Claude Code wrapper for Ollama

USAGE
  claude-local                        Interactive model picker + launch
  claude-local <model> [args...]      Launch with specific model
  claude-local --setup                Configure Ollama connection
  claude-local --test                 Test connectivity & API compatibility
  claude-local --models               List available models
  claude-local --help                 Show this help

ENVIRONMENT
  OLLAMA_HOST              Ollama server URL (default: http://localhost:11434)
  LITELLM_HOST             LiteLLM proxy URL (default: http://localhost:4000)
  OLLAMA_API_KEY           Auth proxy key    (default: none)
  OLLAMA_DEFAULT_MODEL     Auto-select model (default: none / interactive)

  Claude Code connects to LITELLM_HOST (Anthropic Messages API).
  Model discovery uses OLLAMA_HOST (native Ollama API).

CONFIG
  Config is stored at ~/.config/claude-local/.env
  Project-local .env files are also loaded (takes precedence).
  Run --setup for interactive configuration.

EXAMPLES
  claude-local qwen3:8b
  claude-local deepseek-coder-v2 --verbose
  LITELLM_HOST=http://192.168.8.239:4000 claude-local qwen3:8b

HELPEOF
}

###############################################################################
# Main
###############################################################################
main() {
  need_cmd curl
  need_cmd jq

  case "${1:-}" in
    --setup|-s)
      run_setup
      ;;
    --test|-t)
      run_test
      ;;
    --models|--list|-l)
      run_list_models
      ;;
    --help|-h)
      show_help
      ;;
    --*)
      die "Unknown flag: $1  (try --help)"
      ;;
    "")
      # No args — use default model or interactive picker
      if [[ -n "$OLLAMA_DEFAULT_MODEL" ]]; then
        launch_claude "$OLLAMA_DEFAULT_MODEL"
      else
        # First-run detection
        if [[ ! -f "$CONFIG_DIR/.env" && ! -f "$SCRIPT_DIR/.env" ]]; then
          echo -e "${YELLOW}No config found.${NC} Let's set up your Ollama connection."
          echo ""
          run_setup
          echo ""
          # Reload config
          if [[ -f "$CONFIG_DIR/.env" ]]; then
            set -a; source "$CONFIG_DIR/.env"; set +a
          fi
        fi
        pick_model
        launch_claude "$SELECTED_MODEL"
      fi
      ;;
    *)
      # Model name provided as first arg
      local model="$1"
      shift
      launch_claude "$model" "$@"
      ;;
  esac
}

main "$@"
