# claude-code-ollama configuration
# Copy to .env and fill in your values

# Ollama server URL (no trailing slash)
OLLAMA_HOST=https://ollama.lefv.info

# API key (if your Ollama is behind an auth proxy)
OLLAMA_API_KEY=

# Default model to use (leave empty for interactive selection)
OLLAMA_DEFAULT_MODEL=

# Claude Code flags
# Set to 1 to disable telemetry/non-essential traffic
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
