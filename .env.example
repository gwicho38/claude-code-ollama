# claude-code-ollama configuration
# Copy to .env and fill in your values

# Ollama server URL — used for model discovery (no trailing slash)
OLLAMA_HOST=https://ollama.lefv.info

# LiteLLM proxy URL — Claude Code connects here (Anthropic Messages API)
LITELLM_HOST=https://litellm.lefv.info

# API key (if behind an auth proxy like nginx)
OLLAMA_API_KEY=

# Default model to use (leave empty for interactive selection)
OLLAMA_DEFAULT_MODEL=

# Set to 1 to disable telemetry/non-essential traffic
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
